---
const pageTitle = "Internal Policy & Process Knowledge Assistant";
const pageDescription =
  "A grounded GenAI workflow for faster, more reliable answers across internal policies, procedures, and operational documents.";

const metrics = [
  { label: "Internal documents", value: "10" },
  { label: "Structured chunks", value: "92" },
  { label: "Approval records", value: "26" },
  { label: "FAQ pairs", value: "12" },
];

const operationalPain = [
  "The same question could get different answers depending on who replied",
  "Useful documents existed, but the right one was not always the first one found",
  "Experienced team members became informal bottlenecks",
  "Confidence dropped fast when the answer had no visible source",
  "Small process questions still consumed time because finding the answer was harder than it should have been",
];

const complexityBullets = [
  "Answers often lived across more than one document",
  "Formal policies and FAQs did not carry the same authority",
  "Users asked messy, indirect questions rather than neat policy queries",
  "The most similar chunk was not always the most trustworthy one",
  "Good answer quality depended on retrieval discipline before generation",
];

const designResponseBullets = [
  "Build a deliberate corpus, not just a pile of PDFs",
  "Preserve document type and source context in chunk metadata",
  "Prioritize formal documents above FAQ content when both match",
  "Return evidence with the answer so users can trust what they see",
  "Validate retrieval quality instead of stopping at a nice-looking demo",
];

const corpusLayers = [
  {
    title: "Policies",
    text: "Defined what was allowed, limited, or expected across recurring operations scenarios.",
  },
  {
    title: "Procedures and SOPs",
    text: "Defined how work actually got done step by step, especially when the answer depended on process sequencing.",
  },
  {
    title: "Approval records and thresholds",
    text: "Defined who had authority to approve, escalate, or exception-handle decisions.",
  },
  {
    title: "FAQ support content",
    text: "Helped with speed and wording, but was deliberately treated as secondary to formal sources.",
  },
];

const corpusDocs = [
  "Travel & Expense Policy",
  "Reimbursement Rules",
  "Approval Matrix",
  "Procurement Procedure",
  "Vendor Exception Handling Procedure",
  "Employee Onboarding SOP",
  "IT Access Request Process",
  "Incident Escalation Guide",
  "Remote Work Policy",
  "Internal FAQ for Operations",
];

const workflowStages = [
  {
    title: "Stage 1 — Prepare the knowledge",
    items: [
      "PDF ingestion and text extraction",
      "Normalization into structured markdown",
      "Chunking with metadata and source anchors",
    ],
  },
  {
    title: "Stage 2 — Retrieve the right evidence",
    items: [
      "Retrieval against structured chunks",
      "Source-priority reranking",
      "Formal document preference over FAQ content when both are relevant",
    ],
  },
  {
    title: "Stage 3 — Deliver a usable answer",
    items: [
      "Grounded answer generation",
      "Visible evidence stack",
      "Trace logging and lightweight user feedback",
    ],
  },
];

const evaluation = [
  { label: "Primary hit rate @1", value: "0.625" },
  { label: "Primary hit rate @3", value: "0.9792" },
  { label: "Any expected hit rate @1", value: "0.8333" },
  { label: "Any expected hit rate @3", value: "1.0" },
  { label: "Formal document rank 1 count", value: "6 / 6" },
  { label: "FAQ rank 1 count after tuning", value: "0 / 6" },
];

const proofQuestions = [
  {
    tag: "Approval logic",
    text: "What is the approval flow for a standard business expense above €500?",
  },
  {
    tag: "Cross-document operational policy",
    text: "Can a contractor request company hardware directly from IT?",
  },
  {
    tag: "Messy human question",
    text: "I’ve already submitted a late expense claim and I’m missing a receipt. Is this likely to be approved?",
  },
];

const screenshotsLarge = [
  {
    title: "Grounded answer with visible evidence",
    note: "The workflow returns an answer that is usable in context and anchored to supporting source material rather than sounding right by default.",
    path: "/images/projects/northstar/northstar-answer-approval-grounded.png",
    alt: "Grounded answer example for an approval question in the Northstar knowledge assistant",
  },
  {
    title: "More human and ambiguous operational question",
    note: "This is where the workflow becomes more believable: the question is less neat, the answer has to stay careful, and the evidence still matters.",
    path: "/images/projects/northstar/northstar-answer-human-ambiguity.png",
    alt: "Human ambiguous operational question handled by the Northstar knowledge assistant",
  },
];

const screenshotsSmall = [
  {
    title: "Evidence stack close-up",
    note: "Trust comes from showing where the answer came from, not just from sounding fluent.",
    path: "/images/projects/northstar/northstar-answer-evidence-stack.png",
    alt: "Evidence stack and cited sources in the Northstar knowledge assistant",
  },
  {
    title: "Corpus architecture map",
    note: "The corpus was designed around authority and process logic, not just document availability.",
    path: "/images/projects/northstar/northstar-corpus-architecture-map.png",
    alt: "Corpus architecture map for the Northstar internal knowledge assistant",
  },
  {
    title: "Demo home state",
    note: "The Streamlit MVP exposed the ask flow, example prompts, corpus stats, and answer workflow in a simple business-facing interface.",
    path: "/images/projects/northstar/northstar-demo-home.png",
    alt: "Streamlit demo home state for the Northstar internal knowledge assistant",
  },
];

const workStyleBullets = [
  "I started from an operational problem, not from AI hype",
  "I treated corpus design as part of the solution, not as setup",
  "I built for grounded answers, not just fluent answers",
  "I used evaluation to test behavior, not just demo appearance",
];

const portfolioBullets = [
  "Shows applied GenAI relevance without sounding trendy",
  "Demonstrates retrieval and reranking awareness",
  "Proves I can package technical systems in business language",
  "Adds a realistic internal AI workflow case to the portfolio mix",
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle} | Antonio González Martín</title>

    <style>
      :root {
        --bg: #05101e;
        --bg-2: #07182d;
        --bg-3: #0a1f39;

        --text: #f8fafc;
        --soft: #dbe7f4;
        --muted: #9fb0c8;

        --accent-cyan: #7dd3fc;
        --accent-blue: #60a5fa;
        --accent-indigo: #818cf8;
        --accent-teal: #67e8f9;
        --accent-violet: #a78bfa;

        --line: rgba(125, 211, 252, 0.16);
        --line-strong: rgba(125, 211, 252, 0.28);

        --panel: rgba(255, 255, 255, 0.035);
        --panel-strong: rgba(255, 255, 255, 0.05);
        --panel-glass: rgba(255, 255, 255, 0.028);

        --shadow-soft: 0 18px 50px rgba(0, 0, 0, 0.26);
        --shadow-lift: 0 24px 70px rgba(0, 0, 0, 0.34);
        --max: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.7;
        background:
          radial-gradient(circle at 12% 0%, rgba(96, 165, 250, 0.14), transparent 24%),
          radial-gradient(circle at 88% 8%, rgba(167, 139, 250, 0.08), transparent 18%),
          radial-gradient(circle at 50% 100%, rgba(103, 232, 249, 0.05), transparent 30%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 54%, var(--bg-3) 100%);
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px),
          linear-gradient(180deg, rgba(255, 255, 255, 0.012) 1px, transparent 1px);
        background-size: 36px 36px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.18), transparent 32%, transparent 68%, rgba(0, 0, 0, 0.12));
        opacity: 0.22;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .page {
        width: min(var(--max), calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 5rem;
        position: relative;
        z-index: 1;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--muted);
        margin-bottom: 1.8rem;
        font-size: 0.95rem;
        transition: color 220ms ease, transform 220ms ease;
      }

      .back-link:hover {
        color: var(--text);
        transform: translateX(-2px);
      }

      .hero {
        padding: 2rem 0 1.35rem;
        position: relative;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: -3rem -2rem auto auto;
        width: 320px;
        height: 320px;
        background: radial-gradient(circle, rgba(125, 211, 252, 0.14), transparent 68%);
        filter: blur(12px);
        pointer-events: none;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(125, 211, 252, 0.22);
        background: linear-gradient(180deg, rgba(125, 211, 252, 0.11), rgba(255, 255, 255, 0.03));
        color: var(--accent-cyan);
        font-size: 0.84rem;
        margin-bottom: 1.05rem;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
      }

      h1 {
        font-size: clamp(2.4rem, 4.6vw, 4.35rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
        margin: 0 0 1rem;
        max-width: 980px;
      }

      .subtitle {
        max-width: 860px;
        font-size: 1.12rem;
        color: var(--muted);
        margin: 0 0 1.45rem;
      }

      .hero-copy {
        max-width: 820px;
      }

      .hero-copy p {
        margin: 0 0 0.9rem;
        font-size: 1.04rem;
        color: var(--soft);
      }

      .hero-outcome {
        margin-top: 1.15rem;
        max-width: 920px;
        padding: 1rem 1.1rem;
        border-radius: 18px;
        border: 1px solid rgba(125, 211, 252, 0.24);
        background:
          linear-gradient(180deg, rgba(125, 211, 252, 0.11), rgba(255, 255, 255, 0.03)),
          radial-gradient(circle at 0% 0%, rgba(96, 165, 250, 0.08), transparent 40%);
        color: #e7f4ff;
        box-shadow: var(--shadow-soft);
      }

      .metrics-label {
        margin-top: 2rem;
        margin-bottom: 0.85rem;
        font-size: 0.86rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
      }

      .metric {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.025));
        border: 1px solid rgba(125, 211, 252, 0.17);
        border-radius: 20px;
        padding: 1.05rem 1rem 1.15rem;
        box-shadow: var(--shadow-soft);
        transition:
          transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease,
          background 320ms ease;
      }

      .metric::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at top left, rgba(125, 211, 252, 0.1), transparent 55%);
        opacity: 0.8;
        pointer-events: none;
      }

      .metric:hover {
        transform: translateY(-6px);
        border-color: rgba(125, 211, 252, 0.28);
        box-shadow: var(--shadow-lift);
      }

      .metric-bar {
        width: 54px;
        height: 3px;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue));
        margin-bottom: 0.9rem;
      }

      .metric-label {
        font-size: 0.92rem;
        color: var(--muted);
        margin-bottom: 0.4rem;
      }

      .metric-value {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .section {
        position: relative;
        padding-top: 4.4rem;
      }

      .section.theme-cyan::before,
      .section.theme-indigo::before,
      .section.theme-blue::before,
      .section.theme-teal::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.28), transparent);
        opacity: 0.55;
      }

      .section.theme-cyan {
        --section-tint-a: rgba(125, 211, 252, 0.08);
        --section-tint-b: rgba(96, 165, 250, 0.045);
        --section-border: rgba(125, 211, 252, 0.2);
        --section-accent: var(--accent-cyan);
      }

      .section.theme-blue {
        --section-tint-a: rgba(96, 165, 250, 0.09);
        --section-tint-b: rgba(129, 140, 248, 0.04);
        --section-border: rgba(96, 165, 250, 0.19);
        --section-accent: var(--accent-blue);
      }

      .section.theme-indigo {
        --section-tint-a: rgba(129, 140, 248, 0.09);
        --section-tint-b: rgba(96, 165, 250, 0.035);
        --section-border: rgba(129, 140, 248, 0.2);
        --section-accent: var(--accent-indigo);
      }

      .section.theme-teal {
        --section-tint-a: rgba(103, 232, 249, 0.08);
        --section-tint-b: rgba(125, 211, 252, 0.04);
        --section-border: rgba(103, 232, 249, 0.18);
        --section-accent: var(--accent-teal);
      }

      .section h2 {
        font-size: clamp(1.85rem, 3vw, 2.8rem);
        line-height: 1.08;
        letter-spacing: -0.03em;
        margin: 0 0 1rem;
      }

      .section-intro {
        max-width: 920px;
        color: var(--muted);
        margin: 0 0 1.25rem;
        font-size: 1.03rem;
      }

      .split {
        display: grid;
        grid-template-columns: 1.18fr 0.9fr;
        gap: 1.2rem;
      }

      .panel {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.028)),
          radial-gradient(circle at top left, var(--section-tint-a, rgba(125, 211, 252, 0.06)), transparent 48%),
          radial-gradient(circle at bottom right, var(--section-tint-b, rgba(96, 165, 250, 0.03)), transparent 42%);
        border: 1px solid var(--section-border, var(--line));
        border-radius: 22px;
        padding: 1.45rem 1.45rem;
        box-shadow: var(--shadow-soft);
        transition:
          transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .panel::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(120deg, rgba(255, 255, 255, 0.035), transparent 28%, transparent 72%, rgba(255, 255, 255, 0.02));
        opacity: 0.7;
        pointer-events: none;
      }

      .panel:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-lift);
      }

      .panel-strong {
        border-color: rgba(125, 211, 252, 0.28);
      }

      .panel h3 {
        margin: 0 0 0.75rem;
        font-size: 1.15rem;
        line-height: 1.25;
      }

      .panel p {
        margin: 0 0 1rem;
        color: var(--soft);
      }

      .panel p:last-child {
        margin-bottom: 0;
      }

      .lead-strong {
        font-size: 1.08rem;
      }

      .list {
        margin: 0.1rem 0 0;
        padding-left: 1.15rem;
      }

      .list li {
        margin-bottom: 0.65rem;
        color: var(--soft);
      }

      .architecture-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.95fr;
        gap: 1.2rem;
        margin-top: 1.4rem;
        align-items: start;
      }

      .image-panel {
        overflow: hidden;
        padding: 0;
      }

      .image-panel img {
        width: 100%;
        aspect-ratio: 16 / 11;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.03);
        transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .image-panel:hover img {
        transform: scale(1.02);
      }

      .image-caption {
        padding: 1rem 1.1rem 1.15rem;
        color: var(--muted);
        font-size: 0.93rem;
      }

      .layer-grid {
        display: grid;
        gap: 0.9rem;
      }

      .layer-card {
        padding: 1rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.018));
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        transition:
          transform 300ms ease,
          border-color 300ms ease,
          background 300ms ease;
      }

      .layer-card:hover {
        transform: translateY(-4px);
        border-color: rgba(125, 211, 252, 0.2);
      }

      .layer-card h4 {
        margin: 0 0 0.4rem;
        font-size: 1rem;
      }

      .layer-card p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .docs-inline {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 1rem;
      }

      .doc-pill {
        padding: 0.42rem 0.72rem;
        border-radius: 999px;
        border: 1px solid rgba(125, 211, 252, 0.16);
        background: linear-gradient(180deg, rgba(125, 211, 252, 0.08), rgba(255, 255, 255, 0.02));
        color: #e0f4ff;
        font-size: 0.88rem;
        transition:
          transform 260ms ease,
          border-color 260ms ease,
          background 260ms ease;
      }

      .doc-pill:hover {
        transform: translateY(-3px);
        border-color: rgba(125, 211, 252, 0.28);
      }

      .workflow-image {
        overflow: hidden;
        padding: 0;
        margin-top: 1.25rem;
      }

      .workflow-image img {
        width: 100%;
        aspect-ratio: 16 / 7;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.03);
        transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .workflow-image:hover img {
        transform: scale(1.015);
      }

      .workflow-stages {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.2rem;
      }

      .stage-card {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.025)),
          radial-gradient(circle at top left, rgba(129, 140, 248, 0.08), transparent 45%);
        border: 1px solid rgba(129, 140, 248, 0.16);
        border-radius: 18px;
        padding: 1.1rem 1rem 1.1rem;
        transition:
          transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .stage-card:hover {
        transform: translateY(-6px);
        border-color: rgba(129, 140, 248, 0.28);
        box-shadow: var(--shadow-soft);
      }

      .stage-card h3 {
        margin: 0 0 0.7rem;
        font-size: 1.05rem;
        line-height: 1.35;
      }

      .stage-card ul {
        margin: 0;
        padding-left: 1.1rem;
      }

      .stage-card li {
        margin-bottom: 0.55rem;
        color: var(--soft);
      }

      .quote-panel {
        margin-top: 1.15rem;
        padding: 1.2rem 1.25rem;
        border-radius: 22px;
        border: 1px solid rgba(125, 211, 252, 0.24);
        background:
          linear-gradient(180deg, rgba(125, 211, 252, 0.11), rgba(255, 255, 255, 0.03)),
          radial-gradient(circle at left center, rgba(96, 165, 250, 0.08), transparent 42%);
        color: #eaf7ff;
        box-shadow: var(--shadow-soft);
        transition: transform 320ms ease, box-shadow 320ms ease;
      }

      .quote-panel:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lift);
      }

      .quote-panel strong {
        color: white;
      }

      .eval-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.25rem;
      }

      .eval-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
          radial-gradient(circle at top left, rgba(103, 232, 249, 0.07), transparent 44%);
        border: 1px solid rgba(103, 232, 249, 0.16);
        border-radius: 18px;
        padding: 1.1rem 1rem;
        transition:
          transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .eval-card:hover {
        transform: translateY(-6px);
        border-color: rgba(103, 232, 249, 0.26);
        box-shadow: var(--shadow-soft);
      }

      .eval-label {
        color: var(--muted);
        font-size: 0.92rem;
        margin-bottom: 0.45rem;
      }

      .eval-value {
        font-size: 1.8rem;
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .question-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.35rem;
      }

      .question-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.042), rgba(255, 255, 255, 0.02)),
          radial-gradient(circle at top left, rgba(96, 165, 250, 0.07), transparent 46%);
        border: 1px solid rgba(96, 165, 250, 0.15);
        border-radius: 18px;
        padding: 1rem;
        transition:
          transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .question-card:hover {
        transform: translateY(-6px);
        border-color: rgba(96, 165, 250, 0.26);
        box-shadow: var(--shadow-soft);
      }

      .question-tag {
        display: inline-block;
        padding: 0.28rem 0.6rem;
        border-radius: 999px;
        border: 1px solid rgba(125, 211, 252, 0.22);
        background: linear-gradient(180deg, rgba(125, 211, 252, 0.1), rgba(255, 255, 255, 0.03));
        color: var(--accent-cyan);
        font-size: 0.78rem;
        margin-bottom: 0.75rem;
      }

      .question-card p {
        margin: 0;
        color: var(--soft);
      }

      .gallery-large {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.45rem;
      }

      .gallery-small {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1rem;
      }

      .shot-card {
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
          radial-gradient(circle at top left, rgba(167, 139, 250, 0.06), transparent 42%);
        border: 1px solid rgba(167, 139, 250, 0.15);
        border-radius: 22px;
        box-shadow: var(--shadow-soft);
        transition:
          transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .shot-card:hover {
        transform: translateY(-8px);
        border-color: rgba(167, 139, 250, 0.28);
        box-shadow: var(--shadow-lift);
      }

      .shot-card img {
        width: 100%;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.03);
        transition: transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      .shot-card:hover img {
        transform: scale(1.02);
      }

      .gallery-large .shot-card img,
      .gallery-small .shot-card img {
        aspect-ratio: 16 / 10;
      }

      .shot-copy {
        padding: 1rem 1rem 1.05rem;
      }

      .shot-copy h3 {
        margin: 0 0 0.4rem;
        font-size: 1.04rem;
      }

      .shot-copy p {
        margin: 0;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .closing-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.25rem;
      }

      .closing-note {
        margin-top: 1.2rem;
        max-width: 920px;
        color: var(--soft);
      }

      .scope-note {
        max-width: 920px;
        color: var(--soft);
      }

      .final-cta-section {
        padding-top: 3.4rem;
      }

      .final-cta-panel {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.5rem 1.6rem;
        border-radius: 24px;
        border: 1px solid rgba(125, 211, 252, 0.2);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.08), transparent 42%),
          radial-gradient(circle at bottom right, rgba(129, 140, 248, 0.06), transparent 38%);
        box-shadow: var(--shadow-soft);
      }

      .final-cta-copy {
        max-width: 760px;
      }

      .final-cta-kicker {
        margin: 0 0 0.55rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.76rem;
        font-weight: 700;
        color: var(--accent-cyan);
      }

      .final-cta-copy h2 {
        margin: 0 0 0.65rem;
        font-size: clamp(1.45rem, 2.3vw, 2rem);
        line-height: 1.1;
        letter-spacing: -0.03em;
      }

      .final-cta-copy p {
        margin: 0;
        color: var(--muted);
      }

      .final-cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        align-items: center;
        justify-content: flex-end;
      }

      .final-button {
        min-height: 48px;
        padding: 0 1.15rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition:
          transform 220ms ease,
          border-color 220ms ease,
          background 220ms ease,
          box-shadow 220ms ease;
      }

      .final-button:hover {
        transform: translateY(-2px);
      }

      .final-button-primary {
        color: #07101f;
        background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue));
        box-shadow: 0 12px 28px rgba(96, 165, 250, 0.2);
      }

      .final-button-primary:hover {
        box-shadow: 0 16px 32px rgba(96, 165, 250, 0.26);
      }

      .final-button-secondary {
        color: var(--text);
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.04);
      }

      .final-button-secondary:hover {
        border-color: rgba(125, 211, 252, 0.24);
        background: rgba(255, 255, 255, 0.07);
      }

      .footer-space {
        height: 0.75rem;
      }

      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
        will-change: opacity, transform;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .reveal-left {
        opacity: 0;
        transform: translateX(-26px);
        transition:
          opacity 720ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 720ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
      }

      .reveal-left.is-visible {
        opacity: 1;
        transform: translateX(0);
      }

      .reveal-right {
        opacity: 0;
        transform: translateX(26px);
        transition:
          opacity 720ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 720ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
      }

      .reveal-right.is-visible {
        opacity: 1;
        transform: translateX(0);
      }

      @media (max-width: 980px) {
        .metric-grid,
        .split,
        .architecture-grid,
        .workflow-stages,
        .eval-grid,
        .question-grid,
        .gallery-large,
        .gallery-small,
        .closing-grid {
          grid-template-columns: 1fr;
        }

        .page {
          width: min(var(--max), calc(100% - 1.15rem));
        }

        .hero {
          padding-top: 1.2rem;
        }

        h1 {
          font-size: clamp(2.2rem, 10vw, 3.4rem);
        }

        .workflow-image img,
        .image-panel img {
          aspect-ratio: 16 / 10;
        }

        .final-cta-panel {
          flex-direction: column;
          align-items: flex-start;
        }

        .final-cta-actions {
          justify-content: flex-start;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        *,
        *::before,
        *::after {
          animation: none !important;
          transition: none !important;
        }

        .reveal,
        .reveal-left,
        .reveal-right {
          opacity: 1 !important;
          transform: none !important;
        }
      }
    </style>
  </head>

  <body>
    <main class="page">
      <a href="/" class="back-link reveal" style="--delay: 0ms;">← Back to portfolio</a>

      <section class="hero">
        <div class="eyebrow reveal" style="--delay: 40ms;">Applied GenAI • Internal knowledge workflow</div>
        <h1 class="reveal" style="--delay: 80ms;">{pageTitle}</h1>
        <p class="subtitle reveal" style="--delay: 140ms;">{pageDescription}</p>

        <div class="hero-copy">
          <p class="reveal" style="--delay: 200ms;">
            I built this project around a very normal operations problem: the documentation already existed, but people
            still struggled to use it reliably in day-to-day work.
          </p>
          <p class="reveal" style="--delay: 260ms;">
            Instead of treating that as a chatbot prompt problem, I treated it as a knowledge workflow problem. I
            designed a realistic internal document corpus, structured it for retrieval, introduced source-priority
            logic, and built a grounded answer flow that returns responses with visible evidence.
          </p>
        </div>

        <div class="hero-outcome reveal" style="--delay: 320ms;">
          The result is a business-facing GenAI MVP focused on usability, consistency, and trust across internal
          policies, procedures, approvals, and support questions.
        </div>

        <div class="metrics-label reveal" style="--delay: 380ms;">Project scope</div>

        <div class="metric-grid">
          {metrics.map((metric, index) => (
            <div class="metric reveal" style={`--delay: ${420 + index * 70}ms;`}>
              <div class="metric-bar"></div>
              <div class="metric-label">{metric.label}</div>
              <div class="metric-value">{metric.value}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="section theme-cyan">
        <h2 class="reveal">The business problem</h2>

        <div class="split">
          <div class="panel panel-strong reveal-left" style="--delay: 60ms;">
            <h3>Documentation existed. Operational confidence did not.</h3>
            <p class="lead-strong">
              Northstar Operations Ltd. did not have a documentation availability problem. It had a
              <strong> documentation usability problem</strong>.
            </p>
            <p>
              Policies, procedures, SOPs, and support documents were already in place, but that did not mean people
              could get to the right answer quickly when work was actually moving. Employees still searched across
              multiple files, relied on experienced colleagues who “knew where things lived,” and handled similar
              questions with too much variation.
            </p>
            <p>
              The real business question was not whether GenAI could answer questions about documents. It was whether a
              grounded knowledge workflow could make internal documentation meaningfully more usable, reduce search
              friction, and improve answer consistency enough to be worth using in operations.
            </p>
          </div>

          <div class="panel reveal-right" style="--delay: 120ms;">
            <h3>What this looked like in practice</h3>
            <ul class="list">
              {operationalPain.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="section theme-blue">
        <h2 class="reveal">Why this needed more than a chatbot</h2>
        <p class="section-intro reveal" style="--delay: 50ms;">
          This use case sounds simple until you look at how internal answers are actually formed. A useful answer might
          depend on a policy, a procedure, an approval threshold, and an exception rule at the same time.
        </p>
        <p class="section-intro reveal" style="--delay: 110ms;">
          Relevance alone is not enough. The workflow also has to recognize which source is more authoritative, when FAQ
          content should stay secondary, and when a human question is vague enough that the answer should stay careful
          rather than overconfident.
        </p>

        <div class="split">
          <div class="panel reveal-left" style="--delay: 160ms;">
            <h3>What made the problem harder</h3>
            <ul class="list">
              {complexityBullets.map((item) => <li>{item}</li>)}
            </ul>
          </div>

          <div class="panel panel-strong reveal-right" style="--delay: 220ms;">
            <h3>What that meant for the design</h3>
            <ul class="list">
              {designResponseBullets.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="section theme-indigo">
        <h2 class="reveal">Corpus architecture</h2>
        <p class="section-intro reveal" style="--delay: 50ms;">
          Retrieval quality depends heavily on corpus design. This project was stronger because the document set was not
          treated as a flat pile of PDFs, but as a small internal knowledge system with different levels of authority
          and different jobs inside the workflow.
        </p>
        <p class="section-intro reveal" style="--delay: 110ms;">
          The corpus was intentionally structured around document authority, process logic, and support content, so the
          answer layer had a better chance of surfacing not just something relevant, but the right kind of evidence.
        </p>

        <div class="architecture-grid">
          <figure class="panel image-panel reveal-left" style="--delay: 170ms;">
            <img
              src="/images/projects/northstar/northstar-corpus-architecture-map.png"
              alt="Corpus architecture map for the Northstar internal knowledge assistant"
            />
            <figcaption class="image-caption">
              Policies, procedures, approvals, and FAQ content were designed to relate to each other rather than sit as
              isolated files.
            </figcaption>
          </figure>

          <div class="panel reveal-right" style="--delay: 220ms;">
            <h3>How the corpus was structured</h3>

            <div class="layer-grid">
              {corpusLayers.map((layer, index) => (
                <div class="layer-card reveal" style={`--delay: ${260 + index * 60}ms;`}>
                  <h4>{layer.title}</h4>
                  <p>{layer.text}</p>
                </div>
              ))}
            </div>

            <div class="quote-panel reveal" style="--delay: 520ms;">
              <strong>Why that mattered:</strong> it enabled cross-document answers, reduced FAQ over-dominance,
              improved authority-aware retrieval, and made more human operational questions answerable.
            </div>
          </div>
        </div>

        <div class="docs-inline">
          {corpusDocs.map((doc, index) => (
            <span class="doc-pill reveal" style={`--delay: ${140 + index * 28}ms;`}>{doc}</span>
          ))}
        </div>
      </section>

      <section class="section theme-teal">
        <h2 class="reveal">How the answer gets built</h2>
        <p class="section-intro reveal" style="--delay: 50ms;">
          The front-end answer only looks simple because the workflow underneath it is structured. This project was
          designed so that answer quality depended less on model fluency and more on document preparation, source
          control, and evidence selection.
        </p>

        <figure class="panel workflow-image reveal" style="--delay: 120ms;">
          <img
            src="/images/projects/northstar/northstar-answer-workflow-diagram.png"
            alt="Workflow diagram showing how the Northstar knowledge assistant builds an answer"
          />
        </figure>

        <div class="workflow-stages">
          {workflowStages.map((stage, index) => (
            <div class="stage-card reveal" style={`--delay: ${180 + index * 80}ms;`}>
              <h3>{stage.title}</h3>
              <ul>
                {stage.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>

        <div class="quote-panel reveal" style="--delay: 420ms;">
          <strong>Most retrieval systems stop at relevance. This one also cared about authority.</strong>
          <br />
          When a policy and an FAQ were both relevant, the workflow was tuned to rank the formal source first. That
          mattered because the operational value of the answer depended on trust, not just similarity.
        </div>
      </section>

      <section class="section theme-cyan">
        <h2 class="reveal">Proof the workflow behaved as intended</h2>
        <p class="section-intro reveal" style="--delay: 50ms;">
          I did not want the project to stop at “the demo seems to work.” I treated proof as part of the case, combining
          retrieval evaluation, answer-pack validation, and visible product behavior.
        </p>

        <div class="eval-grid">
          {evaluation.map((item, index) => (
            <div class="eval-card reveal" style={`--delay: ${110 + index * 55}ms;`}>
              <div class="eval-label">{item.label}</div>
              <div class="eval-value">{item.value}</div>
            </div>
          ))}
        </div>

        <div class="quote-panel reveal" style="--delay: 420ms;">
          <strong>What mattered most:</strong> the biggest improvement was not just higher retrieval success. It was
          better source ordering. After tuning source-priority logic, formal documents ranked first in all 6
          representative validation cases, while FAQ content no longer dominated rank 1. That is what made the workflow
          more trustworthy.
        </div>

        <div class="question-grid">
          {proofQuestions.map((question, index) => (
            <div class="question-card reveal" style={`--delay: ${180 + index * 80}ms;`}>
              <div class="question-tag">{question.tag}</div>
              <p>{question.text}</p>
            </div>
          ))}
        </div>

        <p class="section-intro reveal" style="margin-top: 1rem; --delay: 340ms;">
          The most meaningful tests were not the cleanest prompts. They were the more human ones, where the workflow had
          to combine policy, process, and uncertainty without sounding overconfident.
        </p>

        <div class="gallery-large">
          {screenshotsLarge.map((shot, index) => (
            <figure class="shot-card reveal" style={`--delay: ${220 + index * 100}ms;`}>
              <img src={shot.path} alt={shot.alt} />
              <figcaption class="shot-copy">
                <h3>{shot.title}</h3>
                <p>{shot.note}</p>
              </figcaption>
            </figure>
          ))}
        </div>

        <div class="gallery-small">
          {screenshotsSmall.map((shot, index) => (
            <figure class="shot-card reveal" style={`--delay: ${280 + index * 80}ms;`}>
              <img src={shot.path} alt={shot.alt} />
              <figcaption class="shot-copy">
                <h3>{shot.title}</h3>
                <p>{shot.note}</p>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

      <section class="section theme-blue">
        <h2 class="reveal">Why this case matters</h2>

        <div class="closing-grid">
          <div class="panel reveal-left" style="--delay: 80ms;">
            <h3>What this says about how I work</h3>
            <ul class="list">
              {workStyleBullets.map((item) => <li>{item}</li>)}
            </ul>
          </div>

          <div class="panel panel-strong reveal-right" style="--delay: 150ms;">
            <h3>Why it strengthens the portfolio</h3>
            <ul class="list">
              {portfolioBullets.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>

        <p class="closing-note reveal" style="--delay: 230ms;">
          This project matters because it shows that I do not think about GenAI as a flashy interface layer. I think
          about it as a workflow that only becomes useful when business context, document structure, retrieval logic,
          and evidence discipline are all doing their job.
        </p>
      </section>

      <section class="section theme-indigo">
        <h2 class="reveal">Current scope and next iteration</h2>
        <p class="scope-note reveal" style="--delay: 70ms;">
          This is still an MVP rather than a production deployment. It does not yet include permission-aware retrieval,
          document freshness governance, enterprise monitoring, or workflow ownership beyond the prototype boundary.
        </p>
        <p class="scope-note reveal" style="--delay: 130ms;">
          That said, those are scaling questions, not proof-of-value questions. The project already demonstrates the
          core point: a grounded internal knowledge workflow can make documentation more usable, answers more
          consistent, and source visibility much easier to trust.
        </p>
      </section>

      <section class="section final-cta-section">
        <div class="final-cta-panel reveal" style="--delay: 80ms;">
          <div class="final-cta-copy">
            <p class="final-cta-kicker">Next step</p>
            <h2>Want to explore more of the portfolio or get in touch?</h2>
            <p>
              You can go back to the selected projects section or contact me directly by email.
            </p>
          </div>

          <div class="final-cta-actions">
            <a class="final-button final-button-secondary" href="/#projects">Back to projects</a>
            <a class="final-button final-button-primary" href="mailto:antonio.business444@gmail.com">
              Contact me
            </a>
          </div>
        </div>
      </section>

      <div class="footer-space"></div>
    </main>

    <script is:inline>
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!reduceMotion) {
        const animated = document.querySelectorAll(".reveal, .reveal-left, .reveal-right");

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.14,
            rootMargin: "0px 0px -40px 0px",
          }
        );

        animated.forEach((el) => observer.observe(el));
      } else {
        document
          .querySelectorAll(".reveal, .reveal-left, .reveal-right")
          .forEach((el) => el.classList.add("is-visible"));
      }
    </script>
  </body>
</html>