---
const siteTitle = "Finance Data Foundation for FP&A and Controlling | Antonio González Martín";
const siteDescription =
  "Finance-focused analytics project demonstrating source-to-target logic, variance analysis, reconciliation controls, and stakeholder-facing reporting.";

const dashboardViews = [
  {
    label: "Page 1",
    title: "FP&A Executive Overview",
    src: "/FP_overview.png",
    alt: "FP&A Executive Overview dashboard",
    summary:
      "A high-level executive page designed to provide immediate visibility into core performance, monthly movement, and business cuts relevant for FP&A and controlling stakeholders.",
  },
  {
    label: "Page 2",
    title: "Variance Analysis",
    src: "/FP_var_analysis.png",
    alt: "Variance Analysis dashboard",
    summary:
      "A diagnostic layer focused on budget vs actual, trend context, and structured interpretation of where performance diverges and why.",
  },
  {
    label: "Page 3",
    title: "Reconciliation & Reporting Controls",
    src: "/FP_RR_Control.png",
    alt: "Reconciliation and Reporting Controls dashboard",
    summary:
      "A control-oriented view built to show reporting consistency, reconciliation logic, and confidence in the underlying finance data foundation.",
  },
  {
    label: "Page 4",
    title: "Management KPI Drivers",
    src: "/FP_KPI_Drivers.png",
    alt: "Management KPI Drivers dashboard",
    summary:
      "A management-facing page focused on KPI movement, operational drivers, and the translation of finance data into clearer decision support.",
  },
];

const architectureLayers = [
  {
    stage: "Bronze",
    title: "Raw finance extracts",
    text: "Contoso Retail DW extracts landed as parquet to preserve source fidelity and support traceable downstream transformations.",
  },
  {
    stage: "Silver",
    title: "Standardized actuals layer",
    text: "Actuals were cleaned, standardized, and enriched to create a consistent analytical base suitable for finance reporting logic.",
  },
  {
    stage: "Silver Finance",
    title: "Account-line and monthly FP&A base",
    text: "Finance-specific modeling created account-level and monthly structures designed for P&L analysis, reporting, and control workflows.",
  },
  {
    stage: "Planning",
    title: "Budget, forecast, OPEX, allocation logic",
    text: "Planning layers were generated to support variance analysis, management visibility, and comparison against actual performance.",
  },
  {
    stage: "Gold",
    title: "Reporting-ready finance facts",
    text: "Curated outputs such as P&L monthly facts and reconciliation tables were prepared for stakeholder-facing reporting consumption.",
  },
  {
    stage: "Power BI",
    title: "Decision-facing reporting layer",
    text: "The final dashboard suite translated the finance data model into executive, diagnostic, and control-oriented reporting views.",
  },
];

const projectSignals = [
  {
    eyebrow: "Finance framing",
    title: "Built for FP&A and controlling credibility",
    text: "The project is structured to signal that the work goes beyond dashboard decoration and into finance-oriented analytical thinking.",
  },
  {
    eyebrow: "Technical depth",
    title: "Data logic before visuals",
    text: "The reporting layer sits on top of transformation logic, reconciliation thinking, and structured source-to-target design.",
  },
  {
    eyebrow: "Stakeholder focus",
    title: "Reporting designed for use",
    text: "Each page was built around how different finance stakeholders consume information: overview, diagnosis, control, and drivers.",
  },
];

const stackTags = [
  "DuckDB",
  "Parquet",
  "Power BI",
  "FP&A",
  "Controlling",
  "Variance Analysis",
  "Reconciliation Logic",
  "Source-to-Target Mapping",
  "Finance Reporting",
  "Business-Facing Analytics",
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={siteDescription} />
    <title>{siteTitle}</title>
  </head>

  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="brand">Antonio González Martín</a>

        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/#about">About</a>
          <a href="/#projects">Projects</a>
          <a href="/#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <section class="project-hero">
        <div class="container">
          <div class="project-hero-shell reveal reveal-up">
            <div class="project-hero-overlay"></div>

            <div class="project-hero-content">
              <p class="section-label">Finance / FP&A / Controlling</p>
              <h1>Finance Data Foundation for FP&amp;A and Controlling</h1>
              <p class="project-hero-subtitle">
                A finance-focused analytics project built to demonstrate source-to-target logic,
                variance thinking, reconciliation controls, and stakeholder-facing reporting through
                a recruiter-ready Power BI suite.
              </p>

              <div class="hero-actions">
                <a class="button button-primary" href="#dashboard-suite">Explore dashboard suite</a>
                <a class="button button-secondary" href="/#projects">Back to homepage</a>
              </div>

              <div class="hero-summary-grid">
                <article class="hero-summary-card">
                  <span class="hero-summary-label">Positioning</span>
                  <strong>FP&amp;A / Controlling credibility</strong>
                  <p>Structured to show finance-oriented analytical thinking rather than generic BI output.</p>
                </article>

                <article class="hero-summary-card">
                  <span class="hero-summary-label">Build</span>
                  <strong>Model + controls + reporting</strong>
                  <p>Combines transformation logic, finance data modeling, and stakeholder-facing dashboards.</p>
                </article>

                <article class="hero-summary-card">
                  <span class="hero-summary-label">Outcome</span>
                  <strong>Decision-ready finance visibility</strong>
                  <p>Designed to support overview, diagnosis, control, and management interpretation.</p>
                </article>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section narrative-section">
        <div class="container narrative-grid">
          <div class="narrative-copy reveal reveal-left">
            <p class="section-label">Project overview</p>
            <h2>More than a dashboard layer.</h2>

            <p class="lead">
              This project was designed as a finance data foundation first and a reporting layer second.
            </p>

            <p>
              The objective was to build something that feels closer to how FP&amp;A, controlling,
              and finance transformation work in real business settings: structured inputs, clear
              reporting logic, and outputs that support explanation, accountability, and decisions.
            </p>

            <p>
              Rather than presenting only polished visuals, the project emphasizes what sits underneath:
              source handling, standardized layers, planning logic, reconciliation thinking, and a
              reporting structure aligned with stakeholder needs.
            </p>
          </div>

          <div class="narrative-panel reveal reveal-right">
            <p class="panel-kicker">What this project is meant to signal</p>
            <ul class="narrative-list">
              <li>Enterprise-style thinking around finance data structure</li>
              <li>Comfort with reporting logic, controls, and variance interpretation</li>
              <li>Ability to translate data foundations into stakeholder-facing dashboards</li>
              <li>Business-facing communication rather than purely technical output</li>
            </ul>
          </div>
        </div>
      </section>

      <section id="dashboard-suite" class="section dashboard-section">
        <div class="container">
          <div class="section-heading reveal reveal-up">
            <p class="section-label">Dashboard suite</p>
            <h2>Four pages, four layers of finance visibility.</h2>
            <p>
              The suite is structured so that each page plays a different role in the reporting
              experience: executive overview, variance diagnosis, reconciliation confidence, and KPI drivers.
            </p>
          </div>

          <div class="dashboard-grid">
            {dashboardViews.map((view, index) => (
              <article
                class="dashboard-card reveal reveal-up"
                style={`--reveal-delay: ${index * 70}ms;`}
              >
                <button
                  type="button"
                  class="dashboard-image-button"
                  data-modal-src={view.src}
                  data-modal-title={view.title}
                  data-modal-text={view.summary}
                  aria-label={`Open ${view.title}`}
                >
                  <div class="dashboard-image-wrap">
                    <img src={view.src} alt={view.alt} loading="lazy" />
                  </div>
                </button>

                <div class="dashboard-card-body">
                  <span class="dashboard-card-label">{view.label}</span>
                  <h3>{view.title}</h3>
                  <p>{view.summary}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section architecture-section">
        <div class="container">
          <div class="section-heading reveal reveal-up">
            <p class="section-label">Architecture</p>
            <h2>From raw extracts to finance-facing reporting.</h2>
            <p>
              The value of the project comes from the full chain: ingestion, standardization,
              finance logic, planning context, curated outputs, and reporting consumption.
            </p>
          </div>

          <div class="architecture-grid">
            {architectureLayers.map((layer, index) => (
              <article
                class="architecture-card reveal reveal-up"
                style={`--reveal-delay: ${index * 55}ms;`}
              >
                <span class="architecture-stage">{layer.stage}</span>
                <h3>{layer.title}</h3>
                <p>{layer.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section signals-section">
        <div class="container">
          <div class="section-heading reveal reveal-up">
            <p class="section-label">What this demonstrates</p>
            <h2>Why this project matters professionally.</h2>
            <p>
              The project is designed to position my profile for finance-facing analytics roles where
              data structure, business interpretation, and reporting confidence all matter.
            </p>
          </div>

          <div class="signals-grid">
            {projectSignals.map((signal, index) => (
              <article
                class="signal-card reveal reveal-up"
                style={`--reveal-delay: ${index * 80}ms;`}
              >
                <p class="panel-kicker">{signal.eyebrow}</p>
                <h3>{signal.title}</h3>
                <p>{signal.text}</p>
              </article>
            ))}
          </div>

          <div class="stack-shell reveal reveal-up" style="--reveal-delay: 220ms;">
            <p class="panel-kicker">Tools and concepts</p>
            <div class="tag-row">
              {stackTags.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
        </div>
      </section>

      <section class="section contact-section">
        <div class="container">
          <div class="contact-card reveal reveal-up">
            <div>
              <p class="section-label">Next step</p>
              <h2>Interested in the finance case study?</h2>
              <p>
                This project is part of a broader portfolio focused on applied analytics, business
                visibility, and decision-support systems.
              </p>
            </div>

            <div class="hero-actions contact-actions">
              <a class="button button-primary" href="/#projects">Back to selected work</a>
              <a class="button button-secondary" href="mailto:antonio.business444@gmail.com">Email me</a>
            </div>
          </div>
        </div>
      </section>

      <div class="media-modal" id="dashboard-modal">
        <div class="media-modal-dialog media-modal-dialog--large">
          <button type="button" class="media-modal-close" data-close-modal>×</button>
          <img id="dashboard-modal-image" src="/FP_overview.png" alt="Finance dashboard preview" />
          <div class="media-modal-caption">
            <strong id="dashboard-modal-title">FP&A Executive Overview</strong>
            <p id="dashboard-modal-text">
              A high-level executive page designed to provide immediate visibility into core performance,
              monthly movement, and business cuts relevant for FP&A and controlling stakeholders.
            </p>
          </div>
        </div>
      </div>
    </main>

    <script is:inline>
      const revealItems = Array.from(document.querySelectorAll(".reveal"));
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      function revealImmediately() {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      if (prefersReducedMotion.matches) {
        revealImmediately();
      } else {
        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            });
          },
          {
            threshold: 0.14,
            rootMargin: "0px 0px -10% 0px",
          }
        );

        revealItems.forEach((item) => revealObserver.observe(item));
      }

      const dashboardModal = document.getElementById("dashboard-modal");
      const dashboardModalImage = document.getElementById("dashboard-modal-image");
      const dashboardModalTitle = document.getElementById("dashboard-modal-title");
      const dashboardModalText = document.getElementById("dashboard-modal-text");

      function openModal(modal) {
        if (!modal) return;
        modal.classList.add("is-open");
        document.body.style.overflow = "hidden";
      }

      function closeModal(modal) {
        if (!modal) return;
        modal.classList.remove("is-open");
        document.body.style.overflow = "";
      }

      document.querySelectorAll(".dashboard-image-button").forEach((button) => {
        button.addEventListener("click", () => {
          const src = button.getAttribute("data-modal-src");
          const title = button.getAttribute("data-modal-title");
          const text = button.getAttribute("data-modal-text");

          if (dashboardModalImage && src) dashboardModalImage.src = src;
          if (dashboardModalTitle && title) dashboardModalTitle.textContent = title;
          if (dashboardModalText && text) dashboardModalText.textContent = text;

          openModal(dashboardModal);
        });
      });

      document.querySelectorAll("[data-close-modal]").forEach((button) => {
        button.addEventListener("click", () => {
          closeModal(button.closest(".media-modal"));
        });
      });

      document.querySelectorAll(".media-modal").forEach((modal) => {
        modal.addEventListener("click", (event) => {
          if (event.target === modal) {
            closeModal(modal);
          }
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeModal(dashboardModal);
        }
      });
    </script>
  </body>
</html>

<style>
  :root {
    --bg: #07101f;
    --text: #edf2ff;
    --muted: #b5c1dc;
    --line: rgba(255, 255, 255, 0.1);
    --accent: #91a9ff;
    --accent-soft: #d8e0ff;
    --shadow: 0 20px 55px rgba(0, 0, 0, 0.24);
    --shadow-soft: 0 12px 30px rgba(0, 0, 0, 0.18);
    --max: 1180px;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--text);
    background:
      radial-gradient(circle at top left, rgba(145, 169, 255, 0.1), transparent 28%),
      linear-gradient(180deg, #06101d 0%, #08111f 55%, #08111f 100%);
    line-height: 1.65;
    position: relative;
    overflow-x: hidden;
  }

  body::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1100px;
    background:
      radial-gradient(circle at 14% 18%, rgba(145, 169, 255, 0.12), transparent 28%),
      linear-gradient(
        180deg,
        rgba(6, 16, 29, 0.08) 0%,
        rgba(6, 16, 29, 0.2) 30%,
        rgba(6, 16, 29, 0.72) 78%,
        rgba(6, 16, 29, 1) 100%
      );
    pointer-events: none;
    z-index: 0;
  }

  main,
  .site-header {
    position: relative;
    z-index: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .container {
    width: min(var(--max), calc(100% - 2rem));
    margin: 0 auto;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(16px);
    background: rgba(6, 16, 29, 0.7);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    min-height: 78px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .nav-links a {
    transition: color 0.18s ease;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-links a:focus-visible,
  .brand:focus-visible,
  .button:focus-visible,
  .dashboard-image-button:focus-visible,
  .media-modal-close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  .project-hero {
    padding: 2.2rem 0 2.2rem;
  }

  .project-hero-shell {
    position: relative;
    overflow: hidden;
    border-radius: 34px;
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: linear-gradient(
      180deg,
      rgba(18, 30, 54, 0.88) 0%,
      rgba(14, 23, 42, 0.94) 100%
    );
    box-shadow: var(--shadow);
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 78% 18%, rgba(145, 169, 255, 0.18), transparent 28%),
      linear-gradient(
        180deg,
        rgba(5, 11, 24, 0.16) 0%,
        rgba(6, 13, 28, 0.42) 34%,
        rgba(6, 13, 28, 0.82) 100%
      );
    pointer-events: none;
  }

  .project-hero-content {
    position: relative;
    z-index: 1;
    padding: 2.7rem 2rem 2rem;
  }

  .section-label {
    margin: 0 0 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--accent-soft);
  }

  h1,
  h2 {
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    max-width: 12ch;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  p {
    margin: 0 0 1rem;
    color: var(--muted);
  }

  .project-hero-subtitle {
    font-size: 1.08rem;
    max-width: 820px;
    margin-top: 1rem;
  }

  .hero-actions,
  .contact-actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .hero-actions {
    margin-top: 1.35rem;
  }

  .button {
    min-height: 50px;
    padding: 0 1.2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    transition:
      transform 0.18s ease,
      background 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--accent);
    color: #081122;
    box-shadow: 0 10px 24px rgba(145, 169, 255, 0.18);
  }

  .button-secondary {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: var(--text);
  }

  .hero-summary-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .hero-summary-card,
  .narrative-panel,
  .dashboard-card,
  .architecture-card,
  .signal-card,
  .stack-shell,
  .contact-card {
    border: 1px solid rgba(255, 255, 255, 0.13);
    background: rgba(20, 31, 54, 0.8);
    box-shadow: var(--shadow);
    backdrop-filter: blur(14px);
  }

  .hero-summary-card {
    border-radius: 22px;
    padding: 1rem 1.05rem;
    background: rgba(22, 35, 61, 0.76);
  }

  .hero-summary-label,
  .panel-kicker,
  .dashboard-card-label,
  .architecture-stage {
    display: inline-block;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--accent-soft);
  }

  .hero-summary-card strong {
    display: block;
    margin-bottom: 0.35rem;
    font-size: 1.05rem;
    line-height: 1.2;
  }

  .hero-summary-card p {
    margin: 0;
    font-size: 0.95rem;
  }

  .section {
    padding: 4.5rem 0;
  }

  .section-heading {
    max-width: 860px;
    margin: 0 auto 1.35rem;
    text-align: center;
  }

  .lead {
    font-size: 1.08rem;
    color: var(--text);
  }

  .narrative-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 1.2rem;
    align-items: start;
  }

  .narrative-panel {
    border-radius: 28px;
    padding: 1.35rem;
    background: rgba(18, 29, 50, 0.84);
  }

  .narrative-list {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .narrative-list li {
    margin-bottom: 0.65rem;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .dashboard-card {
    border-radius: 28px;
    overflow: hidden;
    background: rgba(18, 29, 50, 0.84);
    transition:
      transform 0.22s ease,
      border-color 0.22s ease,
      box-shadow 0.22s ease;
  }

  .dashboard-card:hover,
  .architecture-card:hover,
  .signal-card:hover,
  .narrative-panel:hover {
    transform: translateY(-2px);
    border-color: rgba(145, 169, 255, 0.24);
  }

  .dashboard-image-button {
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    cursor: zoom-in;
    color: inherit;
    text-align: left;
  }

  .dashboard-image-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background:
      radial-gradient(circle at 72% 20%, rgba(145, 169, 255, 0.16), transparent 34%),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.06),
        rgba(255, 255, 255, 0.02)
      );
  }

  .dashboard-image-wrap::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(7, 16, 31, 0.04) 0%,
      rgba(7, 16, 31, 0.16) 56%,
      rgba(7, 16, 31, 0.3) 100%
    );
    pointer-events: none;
  }

  .dashboard-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s var(--ease-out);
  }

  .dashboard-image-button:hover .dashboard-image-wrap img {
    transform: scale(1.03);
  }

  .dashboard-card-body {
    padding: 1rem 1rem 1.1rem;
  }

  .dashboard-card h3,
  .architecture-card h3,
  .signal-card h3 {
    margin: 0 0 0.7rem;
    font-size: 1.38rem;
    line-height: 1.12;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .dashboard-card p,
  .architecture-card p,
  .signal-card p {
    margin: 0;
  }

  .architecture-grid,
  .signals-grid {
    display: grid;
    gap: 1rem;
  }

  .architecture-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .signals-grid {
    grid-template-columns: repeat(3, 1fr);
    margin-bottom: 1.2rem;
  }

  .architecture-card,
  .signal-card {
    border-radius: 24px;
    padding: 1.2rem;
    background: rgba(18, 29, 50, 0.84);
