---
const pageTitle = "Manufacturing / Operations Controlling & Cost-to-Serve";
const pageDescription =
  "A management-facing controlling case built around a harder profitability question: where reported margin overstates real value once setup effort, fragmentation, fulfillment burden, service support, and scarce capacity are treated as part of the decision.";

const heroMetrics = [
  { label: "Decision-support pages", value: "4-page flow" },
  { label: "Burden drivers layered into the case", value: "5 cost-to-serve lenses" },
  { label: "Management action paths", value: "Protect / Reprice / Simplify / Investigate / Deprioritize" },
  { label: "Role positioning", value: "Controlling + FP&A + business-facing analytics" },
];

const whyMarginWasNotEnough = [
  "Standard gross margin gave management a directional view, but not a decision-useful one",
  "Operationally awkward products could still look acceptable because setup, fragmentation, and support effort sat outside the usual product view",
  "That created a real risk: protecting or scaling products that absorbed scarce capacity without creating equivalent economic value",
  "The business needed product-level prioritization, not another page of generic manufacturing KPIs",
];

const buildLayers = [
  {
    title: "Profitability gap view",
    text: "A first page that deliberately contrasts reported margin with a more realistic economic contribution view once cost-to-serve is layered in.",
  },
  {
    title: "Leakage driver diagnosis",
    text: "A second page that surfaces which products are carrying hidden operational leakage and which burden drivers are actually doing the damage.",
  },
  {
    title: "Capacity drag diagnosis",
    text: "A third page that treats scarce operational capacity as a management constraint, not as background noise, so capacity hogs become visible even when margin looks passable.",
  },
  {
    title: "Action prioritization",
    text: "A final page that converts diagnosis into differentiated action paths instead of assuming every weak product deserves the same response.",
  },
];

const costToServeBullets = [
  "Setup effort and changeover burden",
  "Production fragmentation and low-flow operational complexity",
  "Fulfillment burden created by awkward order and shipment patterns",
  "Service and support load after the sale",
  "Capacity strain, where resource consumption matters as much as nominal margin",
];

const pageFlow = [
  {
    title: "1. Reported Margin vs Real Economic Contribution",
    text: "The first question the case answers is simple but important: which products look profitable on paper, yet become far less attractive once operational burden is treated as part of the economics? This is the page that creates tension in the story.",
    image: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-1-profitability-gap.png",
    alt: "Dashboard screenshot for page 1 showing reported margin versus real economic contribution in the manufacturing cost-to-serve case",
    captionTitle: "Where margin starts to mislead",
    captionText: "This page reframes profitability from a reporting number into a management question: which products are still worth protecting once hidden burden is taken seriously?",
  },
  {
    title: "2. Diagnosing Hidden Leakage",
    text: "Once the profitability gap is visible, management needs to know why it exists. This page isolates the products creating the biggest hidden leakage and shows whether the erosion comes from setup intensity, fragmented flow, fulfillment burden, service support, or a combination of drivers.",
    image: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-2-hidden-leakage.png",
    alt: "Dashboard screenshot for page 2 diagnosing hidden leakage drivers in the manufacturing cost-to-serve case",
    captionTitle: "The erosion is not random",
    captionText: "The point is not just to find weak products. It is to understand which operating mechanisms are weakening them, because that changes the response.",
  },
  {
    title: "3. Diagnosing Capacity Hogs",
    text: "Some products do not look disastrous on standard margin, yet they absorb a disproportionate share of scarce operating capacity. This page makes that trade-off visible so management can stop confusing acceptable margin with efficient value creation.",
    image: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-3-capacity-hogs.png",
    alt: "Dashboard screenshot for page 3 diagnosing capacity hog products in the manufacturing cost-to-serve case",
    captionTitle: "Margin and capacity are not the same thing",
    captionText: "This is where the case becomes more credible for controlling roles: it shows that profitability has to be read alongside operational strain, not in isolation.",
  },
  {
    title: "4. Management Action Prioritization",
    text: "The final page turns diagnosis into management action. Products are not all treated the same. Some deserve protection, others repricing, others simplification, deeper investigation, or deliberate deprioritization. That is the decision-support layer the earlier pages build toward.",
    image: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-4-action-prioritization.png",
    alt: "Dashboard screenshot for page 4 showing management action prioritization in the manufacturing cost-to-serve case",
    captionTitle: "Different problems, different decisions",
    captionText: "The case avoids the lazy conclusion that every weak product should simply be cut. It supports differentiated action based on the real source of value erosion.",
  },
];

const managementSignals = [
  "The case shows that I can frame a real controlling problem, not just assemble a report around available fields.",
  "It demonstrates business-facing analytics that connect profitability, operational burden, and management action in one coherent story.",
  "For recruiter-facing positioning, it strengthens my fit for FP&A, controlling, reporting, and decision-support roles where finance logic and operational reality need to be read together.",
];

const toolStack = ["Power BI", "SQL", "Python", "Excel / Power Query", "Analytical data modelling", "Management reporting logic"];

const imageAssets = {
  hero: "/images/projects/manufacturing-cost-to-serve/manufacturing-cost-to-serve-hero.png",
  page1: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-1-profitability-gap.png",
  page2: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-2-hidden-leakage.png",
  page3: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-3-capacity-hogs.png",
  page4: "/images/projects/manufacturing-cost-to-serve/manufacturing-page-4-action-prioritization.png",
};
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle} | Antonio González Martín</title>

    <style>
      :root {
        --bg: #04101c;
        --bg-2: #071726;
        --bg-3: #0a1c2d;

        --text: #f4f7fb;
        --soft: #d8e3f0;
        --muted: #9eb1c6;

        --accent-cyan: #7dd3fc;
        --accent-blue: #60a5fa;
        --accent-indigo: #818cf8;
        --accent-red: #f87171;
        --accent-amber: #fbbf24;
        --accent-green: #4ade80;

        --line: rgba(125, 211, 252, 0.16);
        --line-strong: rgba(125, 211, 252, 0.28);

        --panel: rgba(255, 255, 255, 0.035);
        --panel-strong: rgba(255, 255, 255, 0.05);

        --shadow-soft: 0 18px 50px rgba(0, 0, 0, 0.26);
        --shadow-lift: 0 24px 70px rgba(0, 0, 0, 0.34);
        --max: 1180px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.7;
        background:
          radial-gradient(circle at 12% 0%, rgba(96, 165, 250, 0.14), transparent 24%),
          radial-gradient(circle at 88% 10%, rgba(248, 113, 113, 0.08), transparent 18%),
          radial-gradient(circle at 50% 100%, rgba(129, 140, 248, 0.06), transparent 30%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 54%, var(--bg-3) 100%);
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px),
          linear-gradient(180deg, rgba(255, 255, 255, 0.012) 1px, transparent 1px);
        background-size: 36px 36px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.18), transparent 32%, transparent 68%, rgba(0, 0, 0, 0.12));
        opacity: 0.22;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .page {
        width: min(var(--max), calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 5rem;
        position: relative;
        z-index: 1;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        color: var(--muted);
        margin-bottom: 1.8rem;
        font-size: 0.95rem;
        transition: color 220ms ease, transform 220ms ease;
      }

      .back-link:hover {
        color: var(--text);
        transform: translateX(-2px);
      }

      .hero {
        padding: 2rem 0 1.35rem;
        position: relative;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: -3rem -2rem auto auto;
        width: 340px;
        height: 340px;
        background: radial-gradient(circle, rgba(125, 211, 252, 0.12), transparent 68%);
        filter: blur(12px);
        pointer-events: none;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.42rem 0.8rem;
        border-radius: 999px;
        border: 1px solid rgba(125, 211, 252, 0.22);
        background: linear-gradient(180deg, rgba(125, 211, 252, 0.11), rgba(255, 255, 255, 0.03));
        color: var(--accent-cyan);
        font-size: 0.84rem;
        margin-bottom: 1.05rem;
        box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
      }

      h1 {
        font-size: clamp(2.45rem, 4.8vw, 4.4rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
        margin: 0 0 1rem;
        max-width: 980px;
      }

      .subtitle {
        max-width: 880px;
        font-size: 1.12rem;
        color: var(--muted);
        margin: 0 0 1.45rem;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.02fr 0.98fr;
        gap: 1.2rem;
        align-items: start;
      }

      .hero-copy {
        max-width: 820px;
      }

      .hero-copy p {
        margin: 0 0 0.9rem;
        font-size: 1.04rem;
        color: var(--soft);
      }

      .hero-outcome {
        margin-top: 1.15rem;
        max-width: 920px;
        padding: 1rem 1.1rem;
        border-radius: 18px;
        border: 1px solid rgba(125, 211, 252, 0.24);
        background:
          linear-gradient(180deg, rgba(125, 211, 252, 0.11), rgba(255, 255, 255, 0.03)),
          radial-gradient(circle at 0% 0%, rgba(96, 165, 250, 0.08), transparent 40%);
        color: #e7f4ff;
        box-shadow: var(--shadow-soft);
      }

      .hero-visual {
        overflow: hidden;
        padding: 0;
        border-radius: 24px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.02)),
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.08), transparent 42%);
        border: 1px solid rgba(125, 211, 252, 0.18);
        box-shadow: var(--shadow-soft);
      }

      .hero-visual img {
        width: 100%;
        aspect-ratio: 16 / 10;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.03);
      }

      .hero-visual-copy {
        padding: 1rem 1rem 1.05rem;
      }

      .hero-visual-copy strong {
        display: block;
        margin-bottom: 0.35rem;
        font-size: 1rem;
      }

      .hero-visual-copy p {
        margin: 0;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .metrics-label {
        margin-top: 2rem;
        margin-bottom: 0.85rem;
        font-size: 0.86rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .metric-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
      }

      .metric {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.025));
        border: 1px solid rgba(125, 211, 252, 0.17);
        border-radius: 20px;
        padding: 1.05rem 1rem 1.15rem;
        box-shadow: var(--shadow-soft);
        transition:
          transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease,
          background 320ms ease;
      }

      .metric::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at top left, rgba(125, 211, 252, 0.1), transparent 55%);
        opacity: 0.8;
        pointer-events: none;
      }

      .metric:hover,
      .panel:hover,
      .proof-shot:hover,
      .image-panel:hover,
      .final-cta-panel:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-lift);
      }

      .metric-bar {
        width: 54px;
        height: 3px;
        border-radius: 999px;
        background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue));
        margin-bottom: 0.9rem;
      }

      .metric-label {
        font-size: 0.92rem;
        color: var(--muted);
        margin-bottom: 0.4rem;
      }

      .metric-value {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .section {
        position: relative;
        padding-top: 4.4rem;
      }

      .section::before {
        content: "";
        position: absolute;
        inset: 0 0 auto 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(125, 211, 252, 0.28), transparent);
        opacity: 0.55;
      }

      .section h2 {
        font-size: clamp(1.9rem, 3vw, 2.8rem);
        line-height: 1.08;
        letter-spacing: -0.03em;
        margin: 0 0 1rem;
      }

      .section-intro {
        max-width: 920px;
        color: var(--muted);
        margin: 0 0 1.25rem;
        font-size: 1.03rem;
      }

      .split {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 1.2rem;
      }

      .panel {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.028)),
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.08), transparent 48%),
          radial-gradient(circle at bottom right, rgba(96, 165, 250, 0.04), transparent 42%);
        border: 1px solid rgba(125, 211, 252, 0.18);
        border-radius: 22px;
        padding: 1.45rem;
        box-shadow: var(--shadow-soft);
        transition:
          transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .panel-strong {
        border-color: rgba(125, 211, 252, 0.28);
      }

      .panel h3 {
        margin: 0 0 0.75rem;
        font-size: 1.15rem;
        line-height: 1.25;
      }

      .panel p {
        margin: 0 0 1rem;
        color: var(--soft);
      }

      .panel p:last-child {
        margin-bottom: 0;
      }

      .lead-strong {
        font-size: 1.08rem;
      }

      .list {
        margin: 0.1rem 0 0;
        padding-left: 1.15rem;
      }

      .list li {
        margin-bottom: 0.65rem;
        color: var(--soft);
      }

      .layer-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.2rem;
      }

      .layer-card {
        padding: 1rem;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.018));
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 16px;
        transition:
          transform 300ms ease,
          border-color 300ms ease,
          background 300ms ease;
      }

      .layer-card:hover {
        transform: translateY(-4px);
        border-color: rgba(125, 211, 252, 0.2);
      }

      .layer-card h4 {
        margin: 0 0 0.4rem;
        font-size: 1rem;
      }

      .layer-card p {
        margin: 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .proof-image-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-top: 1.35rem;
      }

      .image-panel,
      .proof-shot {
        overflow: hidden;
        border-radius: 22px;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
          radial-gradient(circle at top left, rgba(167, 139, 250, 0.06), transparent 42%);
        border: 1px solid rgba(167, 139, 250, 0.15);
        box-shadow: var(--shadow-soft);
        transition:
          transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
          border-color 320ms ease,
          box-shadow 320ms ease;
      }

      .image-panel img,
      .proof-shot img {
        width: 100%;
        object-fit: cover;
        background: rgba(255, 255, 255, 0.03);
      }

      .image-panel img {
        aspect-ratio: 16 / 9;
      }

      .proof-shot img {
        aspect-ratio: 16 / 10;
      }

      .image-copy,
      .proof-copy {
        padding: 1rem 1rem 1.05rem;
      }

      .image-copy strong,
      .proof-copy h3 {
        display: block;
        margin: 0 0 0.4rem;
        font-size: 1rem;
      }

      .image-copy p,
      .proof-copy p {
        margin: 0;
        color: var(--muted);
        font-size: 0.94rem;
      }

      .callout {
        margin-top: 1.2rem;
        padding: 1.15rem 1.2rem;
        border-radius: 20px;
        border: 1px solid rgba(125, 211, 252, 0.22);
        background:
          linear-gradient(180deg, rgba(125, 211, 252, 0.11), rgba(255, 255, 255, 0.03)),
          radial-gradient(circle at left center, rgba(96, 165, 250, 0.08), transparent 42%);
        box-shadow: var(--shadow-soft);
      }

      .callout strong {
        color: #ffffff;
      }

      .final-signal-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.2rem;
      }

      .signal-card {
        padding: 1rem 1rem 1.05rem;
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.02));
        border: 1px solid rgba(125, 211, 252, 0.16);
        box-shadow: var(--shadow-soft);
      }

      .signal-card p {
        margin: 0;
        color: var(--soft);
      }

      .final-cta-section {
        padding-top: 3.4rem;
      }

      .final-cta-panel {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.5rem 1.6rem;
        border-radius: 24px;
        border: 1px solid rgba(125, 211, 252, 0.2);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.022)),
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.08), transparent 42%),
          radial-gradient(circle at bottom right, rgba(129, 140, 248, 0.06), transparent 38%);
        box-shadow: var(--shadow-soft);
        transition:
          transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
          box-shadow 320ms ease;
      }

      .final-cta-copy {
        max-width: 760px;
      }

      .final-cta-kicker {
        margin: 0 0 0.55rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.76rem;
        font-weight: 700;
        color: var(--accent-cyan);
      }

      .final-cta-copy h2 {
        margin: 0 0 0.65rem;
        font-size: clamp(1.45rem, 2.3vw, 2rem);
        line-height: 1.1;
        letter-spacing: -0.03em;
      }

      .final-cta-copy p {
        margin: 0;
        color: var(--muted);
      }

      .final-cta-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        align-items: center;
        justify-content: flex-end;
      }

      .final-button {
        min-height: 48px;
        padding: 0 1.15rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition:
          transform 220ms ease,
          border-color 220ms ease,
          background 220ms ease,
          box-shadow 220ms ease;
      }

      .final-button:hover {
        transform: translateY(-2px);
      }

      .final-button-primary {
        color: #07101f;
        background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue));
        box-shadow: 0 12px 28px rgba(96, 165, 250, 0.2);
      }

      .final-button-primary:hover {
        box-shadow: 0 16px 32px rgba(96, 165, 250, 0.26);
      }

      .final-button-secondary {
        color: var(--text);
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.04);
      }

      .final-button-secondary:hover {
        border-color: rgba(125, 211, 252, 0.24);
        background: rgba(255, 255, 255, 0.07);
      }

      .footer-space {
        height: 0.75rem;
      }

      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
        will-change: opacity, transform;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .reveal-left {
        opacity: 0;
        transform: translateX(-26px);
        transition:
          opacity 720ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 720ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
      }

      .reveal-left.is-visible {
        opacity: 1;
        transform: translateX(0);
      }

      .reveal-right {
        opacity: 0;
        transform: translateX(26px);
        transition:
          opacity 720ms cubic-bezier(0.22, 1, 0.36, 1),
          transform 720ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--delay, 0ms);
      }

      .reveal-right.is-visible {
        opacity: 1;
        transform: translateX(0);
      }

      @media (max-width: 980px) {
        .hero-grid,
        .metric-grid,
        .split,
        .layer-grid,
        .proof-image-grid,
        .final-signal-grid {
          grid-template-columns: 1fr;
        }

        .page {
          width: min(var(--max), calc(100% - 1.15rem));
        }

        .hero {
          padding-top: 1.2rem;
        }

        h1 {
          font-size: clamp(2.2rem, 10vw, 3.4rem);
        }

        .final-cta-panel {
          flex-direction: column;
          align-items: flex-start;
        }

        .final-cta-actions {
          justify-content: flex-start;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        *,
        *::before,
        *::after {
          animation: none !important;
          transition: none !important;
        }

        .reveal,
        .reveal-left,
        .reveal-right {
          opacity: 1 !important;
          transform: none !important;
        }
      }

      .proof-image-grid-four {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .mini-caption {
        margin-top: 0.9rem;
        padding-top: 0.85rem;
        border-top: 1px solid rgba(125, 211, 252, 0.14);
        display: grid;
        gap: 0.32rem;
      }

      .mini-caption strong {
        font-size: 0.92rem;
        color: #eef6ff;
      }

